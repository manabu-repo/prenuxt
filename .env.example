# Default environment (used for production/local if no mode-specific file is loaded)
# Copy this to .env and fill values for your environment.

# Server API base (server-only)
API_BASE_URL=https://api.example.com

# Public config exposed to client (prefix with NUXT_PUBLIC_)
NUXT_PUBLIC_APP_NAME=PreNuxt
NUXT_PUBLIC_APP_VERSION=1.0.0
NUXT_PUBLIC_API_BASE_URL=https://api.example.com/api
